{
  "name": "better-commit",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@hookform/resolvers": "^5.2.2",
      "@tailwindcss/postcss": "^4.2.1",
      "@types/node": "^25.5.2",
      "@types/react": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "lucide-react": "^0.577.0",
      "motion": "^12.35.2",
      "next": "16.1.6",
      "next-themes": "^0.4.6",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "react-hook-form": "^7.71.2",
      "react-hotkeys-hook": "^5.2.4",
      "server-only": "^0.0.1",
