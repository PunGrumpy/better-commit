{
  "name": "@better-commit/cli",
  "version": "1.0.0",
  "description": "TypeScript-first conventional commits: commit.config.ts, plugins, optional AI",
  "keywords": [
    "ai",
    "better-commit",
    "commit",
    "conventional-commits"
  ],
  "license": "MIT",
  "author": "Noppakorn Kaewsalabnil <hello@pungrumpy.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pungrumpy/better-commit.git"
  },
  "bin": {
    "bc": "dist/index.mjs",
    "better-commit": "dist/index.mjs"
  },
  "files": [
    "config",
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/public-config.d.mts",
      "import": "./dist/public-config.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@clack/prompts": "^1.2.0",
    "commander": "^14.0.3",
    "execa": "^9.5.2",
    "jiti": "^2.6.1",
    "openai": "^6.34.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "catalog:",
    "tsdown": "^0.21.2",
    "typescript": "catalog:"
  }
}
